# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Safe to commit. Copy to .env and fill in real values.
# NEVER commit your actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Authentication ────────────────────────────────────────────────────────
# Generate a strong secret, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=change-me-to-a-long-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set this to your Netlify frontend URL (and any custom domain).
# e.g. https://your-app.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=https://your-app.netlify.app,https://yourdomain.com

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
# Leave blank if your backend host (Railway/Render/Fly) handles TLS for you.
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Pipeline Configuration ───────────────────────────────────────────────────
PORT=3000
TIMEFRAME=1m

# ── Multi-Asset Configuration ─────────────────────────────────────────────────
# Add or remove symbols here — comma-separated, no spaces.
# Each symbol runs its own independent pipeline.
# Supported: any Kraken pair e.g. BTC-USDT, ETH-USDT, SOL-USDT, XRP-USDT, ADA-USDT
# The frontend will automatically show a tab for each symbol.
#
# TO ADD A NEW ASSET:
#   1. Add it to SYMBOLS below (backend)
#   2. Add it to VITE_SYMBOLS in frontend/.env (frontend)
#   3. Restart both backend and frontend
#
SYMBOLS=BTC-USDT,ETH-USDT,SOL-USDT

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Requests per minute per client IP. Default 120 — frontend with 3 symbols
# polls ~90 req/min so 60 is too low for multi-symbol operation.
RATE_LIMIT_RPM=120

# ── Journal / Logging ─────────────────────────────────────────────────────────
# Directory where daily JSONL log files are written.
# Logs are compressed after 1 hour and retained for 7 days.
LOG_DIR=./logs

# ── Replay Mode ───────────────────────────────────────────────────────────────
# Path to a CSV file for historical replay.
# Format: timestamp,open,high,low,close,volume
# Leave blank to disable replay mode.
REPLAY_CSV_PATH=
